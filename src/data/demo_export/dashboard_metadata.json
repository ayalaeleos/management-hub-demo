{
  "description": "Dashboard configuration, constants, and metadata",
  "dashboards": [
    {
      "id": "compliance",
      "name": "Compliance",
      "description": "Eleos Compliance Dashboard - Track compliance metrics across 9 checkpoint categories"
    },
    {
      "id": "documentation",
      "name": "Documentation",
      "description": "Eleos Documentation Dashboard - Monitor note generation and provider adoption"
    }
  ],
  "complianceDashboard": {
    "tabs": [
      {
        "id": "overview",
        "label": "Overview",
        "description": "High-level compliance metrics and trends"
      },
      {
        "id": "checkpoints",
        "label": "Checkpoints",
        "description": "Detailed checkpoint-level analysis with 9 categories"
      }
    ],
    "checkpoints": {
      "order": [
        "completeness",
        "uniqueness",
        "progressMentioned",
        "goldenThread",
        "interventionUsed",
        "clientResponse",
        "compliantPlan",
        "barriersAddressed",
        "serviceCodeMatch"
      ],
      "labels": {
        "completeness": "Completeness",
        "uniqueness": "Uniqueness",
        "progressMentioned": "Progress Mentioned",
        "goldenThread": "Golden Thread",
        "interventionUsed": "Intervention Used",
        "clientResponse": "Client Response",
        "compliantPlan": "Compliant Plan",
        "barriersAddressed": "Barriers Addressed",
        "serviceCodeMatch": "Service Code Match"
      },
      "descriptions": {
        "completeness": "Percentage of documentation fields completed",
        "uniqueness": "Lower is better - measures copy/paste detection",
        "progressMentioned": "Documentation explicitly mentions client progress",
        "goldenThread": "Continuity across sessions is maintained",
        "interventionUsed": "Clinical interventions are documented",
        "clientResponse": "Client reactions and responses are captured",
        "compliantPlan": "Treatment plan meets compliance requirements",
        "barriersAddressed": "Barriers to treatment are identified and addressed",
        "serviceCodeMatch": "Service codes match documented activities"
      }
    },
    "colors": {
      "primary": "#1890ff",
      "success": "#52c41a",
      "warning": "#faad14",
      "danger": "#f5222d",
      "neutral": "#8c8c8c",
      "checkpointPalette": [
        "#8884d8",
        "#82ca9d",
        "#ffc658",
        "#ff7c7c",
        "#8dd1e1",
        "#d084d0",
        "#a4de6c",
        "#ffb347",
        "#8e44ad"
      ]
    },
    "thresholds": {
      "qualityScore": {
        "excellent": 90,
        "good": 85,
        "needsImprovement": 80
      },
      "checkpoint": {
        "high": 90,
        "medium": 75,
        "low": 60
      }
    }
  },
  "documentationDashboard": {
    "tabs": [
      {
        "id": "overview",
        "label": "Overview",
        "description": "Key metrics: notes generated, time saved, adoption rates"
      },
      {
        "id": "provider-view",
        "label": "Provider View",
        "description": "Provider-level detail with segmentation and top performers"
      }
    ],
    "providerSegments": {
      "order": [
        "powerProviders",
        "awaitingFirstUse",
        "onboardingSlowStart",
        "lowEngagement",
        "droppedOff"
      ],
      "labels": {
        "powerProviders": "Power Providers",
        "awaitingFirstUse": "Awaiting First Use",
        "onboardingSlowStart": "Onboarding - Slow Start",
        "lowEngagement": "Low Engagement",
        "droppedOff": "Dropped Off"
      },
      "descriptions": {
        "powerProviders": "High-volume, consistent users (>100 notes)",
        "awaitingFirstUse": "Configured but haven't submitted first note",
        "onboardingSlowStart": "First note >2 weeks ago, <10 total notes",
        "lowEngagement": "Active but significantly below average usage",
        "droppedOff": "No notes in last 30+ days"
      }
    },
    "colors": {
      "liveSession": "#1890ff",
      "textSummary": "#52c41a",
      "activityTypes": {
        "individual": "#8884d8",
        "other": "#82ca9d",
        "caseManagement": "#ffc658",
        "peerSupport": "#ff7c7c",
        "playTherapy": "#8dd1e1",
        "armhs": "#d084d0",
        "earlyChildhood": "#a4de6c",
        "psychiatry": "#ffb347"
      }
    },
    "referenceDate": "2026-04-02",
    "timeWindows": {
      "last7Days": "2026-03-26",
      "last30Days": "2026-03-03",
      "last90Days": "2026-01-02"
    }
  },
  "chartConfiguration": {
    "interactiveLegends": true,
    "legendToggles": true,
    "description": "All 12 charts support legend toggles for showing/hiding series",
    "animationDuration": 300,
    "responsiveBreakpoint": 768
  },
  "filterConfiguration": {
    "globalFilters": ["programs", "supervisors", "providers"],
    "filterBehavior": {
      "applyOnChange": false,
      "requireApply": true,
      "allowClear": true
    },
    "filterScope": "All checkpoint tables respond to global dashboard filters"
  },
  "tableConfiguration": {
    "defaultPageSize": 10,
    "pageSizeOptions": [10, 25, 50, 100],
    "features": {
      "search": true,
      "sorting": true,
      "export": true,
      "exportFormats": ["CSV", "Excel"]
    },
    "description": "All checkpoint tables support search, sorting, and export"
  },
  "brandingTheme": {
    "name": "Superset Eleos",
    "description": "Pixel-perfect replica of Superset design system",
    "colors": {
      "background": "#f5f5f5",
      "headerBackground": "#001529",
      "sidebarBackground": "#001529",
      "cardBackground": "#ffffff",
      "border": "#d9d9d9",
      "textPrimary": "#262626",
      "textSecondary": "#8c8c8c"
    },
    "typography": {
      "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial",
      "fontSize": {
        "base": 14,
        "heading1": 24,
        "heading2": 20,
        "heading3": 16,
        "small": 12
      }
    },
    "spacing": {
      "compact": true,
      "cardPadding": "16px",
      "sectionSpacing": "16px"
    }
  },
  "iconLibrary": "lucide-react",
  "simulatedBackendLatency": {
    "enabled": true,
    "delayMs": 300,
    "description": "Simulated latency added to data fetching operations for realistic UX"
  }
}
